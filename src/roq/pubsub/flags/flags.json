{
  "name": "Flags",
  "type": "flags",
  "values": [
    {
      "name": "config_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "description": "config file (path)"
    },
    {
      "name": "secrets_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "description": "secrets file (path, optional)"
    },
    {
      "name": "exchange",
      "type": "std::string",
      "validator": "roq::core::flags::NonEmpty<std::string>",
      "default": "pubsub",
      "description": "exchange identifier (string)"
    },
    {
      "name": "rest_uri",
      "type": "roq::core::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "https://testnet.binance.com",
      "description": "REST end-point (URI)"
    },
    {
      "name": "rest_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "rest_ping_path",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "default": "/api/v3/time",
      "description": "URI path used for REST connection keep-alive messages"
    },
    {
      "name": "rest_request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "30s",
      "description": "request: timeout"
    },
    {
      "name": "rest_listen_key_refresh",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "1800s",
      "description": "listen key refresh period"
    },
    {
      "name": "rest_order_recv_window",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5000ms",
      "description": "receive window, please refer to Binance documentation!"
    },
    {
      "name": "rest_cancel_on_disconnect",
      "type": "bool",
      "default": false,
      "description": "cancel orders on disconnect? (bool)"
    },
    {
      "name": "ws_uri",
      "type": "roq::core::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "wss://testnet.binance.com/realtime",
      "description": "WebSocket end-point (URI)"
    },
    {
      "name": "ws_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "ws_max_subscriptions_per_stream",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 128,
      "description": "max symbols per connection (count)"
    },
    {
      "name": "ws_subscribe_depth_levels",
      "type": "uint32_t",
      "default": 1000,
      "description": "depth levels (count)"
    },
    {
      "name": "ws_subscribe_depth_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "100ms",
      "description": "depth update frequency"
    },
    {
      "name": "ws_mbp_request_delay",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "10s",
      "description": "request delay"
    },
    {
      "name": "ws_mbp_request_max_retries",
      "type": "uint32_t",
      "default": 3,
      "description": "request max retries"
    },
    {
      "name": "ws_subscribe_trade_details",
      "type": "bool",
      "default": false,
      "description": "report individual matches for trade summary? (bool)"
    },
    {
      "name": "request_limit",
      "type": "uint32_t",
      "default": "8",
      "description": "request limit per interval"
    },
    {
      "name": "request_limit_interval",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "request limit monitor interval"
    },
    {
      "name": "encode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 1048576,
      "description": "encode buffer size"
    },
    {
      "name": "decode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 10485760,
      "description": "decode buffer size"
    },
    {
      "name": "mbp_allow_price_inversion",
      "type": "bool",
      "default": false,
      "description": "allow price inversion?"
    }
  ]
}
